
'use client';
import { useEffect, useState } from 'react';
import { supabase } from '@/lib/supabaseClient';

export default function Items(){
  const [session, setSession] = useState(null);
  const [rows, setRows] = useState([]);
  const [title, setTitle] = useState('');
  const [desc, setDesc] = useState('');
  const [category, setCategory] = useState('');
  const [collectionId, setCollectionId] = useState('');
  const [collections, setCollections] = useState([]);
  const [file, setFile] = useState(null);

  useEffect(()=>{
    (async()=>{
      const { data: { session } } = await supabase.auth.getSession();
      setSession(session);
      if(session){ await loadCollections(); await load(); }
    })();
  },[]);

  async function load(){
    const { data } = await supabase
      .from('items')
      .select('id,title,description,category,photo_url,collection_id,created_at')
      .order('created_at', { ascending:false });
    setRows(data||[]);
  }

  async function loadCollections(){
    const { data } = await supabase.from('collections').select('id,title').order('created_at', { ascending:false });
    setCollections(data||[]);
  }

  async function create(e){
    e.preventDefault();
    if(!session) return alert('Login required');

    let photo_url = null;
    if(file){
      const path = `${session.user.id}/${Date.now()}-${file.name}`;
      const { error: upErr } = await supabase.storage.from('item-photos').upload(path, file, { upsert: false });
      if(upErr){ alert(upErr.message); return; }
      const { data: pub } = await supabase.storage.from('item-photos').getPublicUrl(path);
      photo_url = pub?.publicUrl || null;
    }

    const { error } = await supabase.from('items').insert({
      title, description: desc, category, photo_url, collection_id: collectionId || null
    });
    if(error) return alert(error.message);
    setTitle(''); setDesc(''); setCategory(''); setCollectionId(''); setFile(null);
    await load();
  }

  async function remove(id){
    if(!confirm('Delete item?')) return;
    const { error } = await supabase.from('items').delete().eq('id', id);
    if(error) alert(error.message); else load();
  }

  if(!session) return <p>Please <a href="/login">login</a> to manage items.</p>;

  return (
    <div className="grid" style={{gap:24}}>
      <div className="card">
        <h2>Add item</h2>
        <form onSubmit={create} className="grid">
          <input className="input" placeholder="Title" value={title} onChange={e=>setTitle(e.target.value)} required/>
          <input className="input" placeholder="Category" value={category} onChange={e=>setCategory(e.target.value)} />
          <textarea className="textarea" placeholder="Description" rows={3} value={desc} onChange={e=>setDesc(e.target.value)} />

          <label>Assign to collection (optional)</label>
          <select className="select" value={collectionId} onChange={e=>setCollectionId(e.target.value)}>
            <option value="">— None —</option>
            {collections.map(c => <option key={c.id} value={c.id}>{c.title}</option>)}
          </select>

          <label>Photo (optional)</label>
          <input type="file" accept="image/*" onChange={e=>setFile(e.target.files?.[0]||null)} />

          <button className="btn" type="submit">Create</button>
        </form>
      </div>

      <div className="card">
        <h2>Your items</h2>
        <div className="grid">
          {rows.map(r => (
            <div key={r.id} className="card" style={{display:'flex',gap:12,alignItems:'center'}}>
              {r.photo_url && <img src={r.photo_url} width={64} height={64} style={{borderRadius:8,objectFit:'cover'}} alt=""/>}
              <div style={{flex:1}}>
                <strong>{r.title}</strong>
                <div className="muted">{r.category||'—'}</div>
                {r.collection_id && <div className="muted">Collection: {r.collection_id}</div>}
              </div>
              <button className="btn" onClick={()=>remove(r.id)}>Delete</button>
            </div>
          ))}
          {rows.length===0 && <p>No items yet.</p>}
        </div>
      </div>
    </div>
  );
}
